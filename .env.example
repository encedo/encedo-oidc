# Server
PORT=3000
NODE_ENV=development

# Issuer URL — musi zgadzać się z tym co widzi RP (Nextcloud, rp-server itp.)
# Dev:  http://localhost:3000
# Prod: https://oidc.example.com
ISSUER=http://localhost:3000

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Admin API — zmień przed deployem!
ADMIN_SECRET=dev-secret-change-me

# Opcjonalne — client_id testowego RP (rp-server.mjs)
# RP_CLIENT_ID=your-client-id-here
