# Server
PORT=3000
NODE_ENV=development

# Issuer URL -- must match the URL visible to the RP (e.g. Nextcloud)
# Dev:  http://localhost:3000
# Prod: https://oidc.example.com
ISSUER=http://localhost:3000

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Admin API secret -- change before deploying to production!
ADMIN_SECRET=dev-secret-change-me

# Optional -- client_id of the test RP (rp-server.mjs)
# RP_CLIENT_ID=your-client-id-here

# --- SMTP (email enrollment link) -----------------------------------------
# Optional. The "Email link" feature is disabled unless SMTP_HOST and MAIL_FROM
# are both set. DKIM/SPF/DMARC are handled by the mail server -- the app only
# sends over authenticated TLS. Put the real password in the tenant .env only
# (chmod 600), never in the repo.
# SMTP_HOST=mailserver.example.com
# SMTP_MODE=starttls        # starttls = STARTTLS upgrade (587)  |  ssl = implicit TLS (465)
# SMTP_PORT=587             # optional -- defaults to 587 (starttls) / 465 (ssl)
# SMTP_USER=support@example.com
# SMTP_PASS=change-me       # leave empty if the relay authorises by IP
# MAIL_FROM="Encedo <do-not-reply@example.com>"
